</main>

<footer class="site-footer">
  <div class="wrap site-footer__inner">
    <div class="site-footer__brand">
      <span class="brand__mark">JR</span>
      <p>Small-batch screen-printed tees. Cut and printed to fit your style.</p>
    </div>
    <nav aria-label="Footer" class="site-footer__nav">
      <a href="/">Home</a>
      <a href="/shop">Shop</a>
      <a href="/cart">Cart</a>
    </nav>
    <p class="site-footer__legal">&copy; <%= new Date().getFullYear() %> <%= site.name %>. All rights reserved.</p>
  </div>
</footer>

<aside id="mini-cart" class="mini-cart" aria-hidden="true" aria-label="Shopping cart">
  <div class="mini-cart__backdrop" data-mini-cart-close></div>
  <div class="mini-cart__panel" role="dialog" aria-modal="true" aria-labelledby="mini-cart-title" tabindex="-1">
    <header class="mini-cart__head">
      <h2 id="mini-cart-title" class="mini-cart__title">Your Cart <span class="mini-cart__count">(<span data-mini-cart-count>0</span>)</span></h2>
      <button type="button" class="mini-cart__close" aria-label="Close cart" data-mini-cart-close>&times;</button>
    </header>
    <ul class="mini-cart__items" id="mini-cart-items" aria-live="polite"></ul>
    <p class="mini-cart__empty" id="mini-cart-empty" hidden>Your cart is empty. <a href="/shop" class="link" data-mini-cart-close>Browse the shop &rarr;</a></p>
    <footer class="mini-cart__foot">
      <div class="mini-cart__total">
        <span>Subtotal</span>
        <span>$<span data-mini-cart-subtotal>0.00</span></span>
      </div>
      <a href="/cart" class="btn btn--ghost btn--block">View full cart</a>
      <button type="button" class="btn btn--primary btn--block" id="mini-cart-checkout" disabled>Checkout (coming soon)</button>
    </footer>
  </div>
</aside>

<script>
// Server-rendered cart snapshot so the mini-cart opens populated without a round-trip.
window.__INITIAL_CART__ = <%- JSON.stringify({ count: cartCount, subtotal: cartSubtotal }) %>;
</script>
<script src="/js/cart.js" defer></script>
<script src="/js/mini-cart.js" defer></script>
<% if (typeof pageScript !== 'undefined') { %><script src="<%= pageScript %>" defer></script><% } %>
</body>
</html>
