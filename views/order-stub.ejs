<%- include('partials/head') %>
<%- include('partials/header') %>

<section class="page-head">
  <div class="wrap">
    <p class="hero__eyebrow">Stub Provider</p>
    <h1 class="page-head__title">Confirm Order</h1>
    <p class="page-head__lede">
      Order <code><%= order.id %></code> &middot; This is a placeholder payment screen.
      Swap this view for a redirect to your real payment provider (e.g. Stripe Checkout)
      when you wire one in.
    </p>
  </div>
</section>

<section class="cart-page">
  <div class="wrap cart-page__layout">
    <div class="cart-page__items">
      <ul class="cart-items">
        <% order.items.forEach(it => { %>
          <li class="cart-line">
            <div class="cart-line__media">
              <img src="<%= it.image %>" alt="<%= it.name %>" width="96" height="96">
            </div>
            <div class="cart-line__body">
              <div class="cart-line__head">
                <div>
                  <h3 class="cart-line__name"><%= it.name %></h3>
                  <p class="cart-line__meta"><%= it.color %> &middot; Size <%= it.size %> &middot; Qty <%= it.qty %></p>
                </div>
                <p class="cart-line__price">$<%= (it.price * it.qty).toFixed(2) %></p>
              </div>
            </div>
          </li>
        <% }) %>
      </ul>
    </div>

    <aside class="cart-page__summary" aria-label="Order summary">
      <div class="summary">
        <h2 class="summary__title">Total due</h2>
        <dl class="summary__rows">
          <div><dt>Subtotal</dt><dd>$<%= order.subtotal.toFixed(2) %></dd></div>
          <div><dt>Shipping</dt><dd>$0.00 (stub)</dd></div>
          <div class="summary__total"><dt>Total</dt><dd>$<%= order.subtotal.toFixed(2) %></dd></div>
        </dl>

        <form method="post" action="/order/stub/<%= order.id %>/pay">
          <button type="submit" class="btn btn--primary btn--block">Pay (Stub)</button>
        </form>
        <form method="post" action="/order/stub/<%= order.id %>/cancel">
          <button type="submit" class="btn btn--ghost btn--block">Cancel</button>
        </form>
      </div>
    </aside>
  </div>
</section>

<%- include('partials/footer') %>
