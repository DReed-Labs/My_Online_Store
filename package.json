{
  "name": "jrs-thread-shop",
  "version": "0.1.0",
  "private": true,
  "description": "JRs Thread Shop — server-rendered streetwear tee store (Express + EJS, mobile-first).",
  "main": "server.js",
  "scripts": {
    "start": "node --no-warnings=ExperimentalWarning server.js",
    "dev": "node --no-warnings=ExperimentalWarning --watch server.js",
    "migrate": "node --no-warnings=ExperimentalWarning -e \"require('./db/migrate')()\""
  },
  "engines": {
    "node": ">=22.5"
  },
  "dependencies": {
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-session": "^1.19.0"
  }
}
